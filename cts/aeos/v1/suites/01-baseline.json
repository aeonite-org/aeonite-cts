      "id": "baseline-009",
      "description": "Closed-world schemas reject unexpected bindings",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "a" }
              ]
            },
            "key": "a",
            "value": {
