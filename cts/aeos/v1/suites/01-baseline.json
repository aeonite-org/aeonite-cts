  "id": "baseline",
  "title": "Baseline Invariants",
  "tests": [
    {
      "id": "baseline-001",
      "description": "Duplicate binding paths are rejected",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "StringLiteral",
              "value": "one",
              "raw": "\"one\""
            },
            "span": {
              "start": { "offset": 0 },
              "end": { "offset": 9 }
            }
          },
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "StringLiteral",
              "value": "two",
              "raw": "\"two\""
            },
            "span": {
              "start": { "offset": 10 },
              "end": { "offset": 19 }
            }
          }
        ],
        "schema": {
          "rules": []
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "duplicate_binding",
            "phase": "schema_validation",
            "span": [10, 19]
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
