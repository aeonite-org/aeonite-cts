              "end": { "offset": 7 }
            }
          },
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "b" }
              ]
            },
            "key": "b",
            "value": {
              "type": "StringLiteral",
              "value": "extra",
              "raw": "\"extra\"",
              "delimiter": "\"",
              "span": {
