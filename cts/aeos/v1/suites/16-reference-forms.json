{
  "meta": {
    "suite_id": "reference-forms",
    "spec_refs": ["specs/03-releases/r5/AEOS-spec-r5.md"],
    "constraint_primitives": ["reference-form-constraints", "core-vs-aeos-boundary"]
  },
  "id": "reference-forms",
  "title": "Reference Form Constraints",
  "tests": [
    {
      "id": "reference-form-001",
      "description": "Schema reference_policy=forbid rejects reference-valued bindings",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "CloneReference",
              "path": ["target"],
              "span": [4, 11]
            },
            "span": [0, 11]
          }
        ],
        "schema": {
          "rules": [],
          "reference_policy": "forbid"
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "reference_forbidden",
            "phase": "schema_validation",
            "span": [0, 11]
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-002",
      "description": "reference=require accepts either clone or pointer when reference_kind is omitted",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "PointerReference",
              "path": ["target"],
              "span": [4, 12]
            },
            "span": [0, 12]
          }
        ],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "require"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-003",
      "description": "reference=require rejects non-reference values",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "StringLiteral",
              "value": "plain",
              "raw": "\"plain\""
            },
            "span": [0, 9]
          }
        ],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "require"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "reference_required",
            "phase": "schema_validation",
            "span": [0, 9]
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-004",
      "description": "reference_kind=clone rejects pointer references",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "PointerReference",
              "path": ["target"],
              "span": [4, 12]
            },
            "span": [0, 12]
          }
        ],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "require",
                "reference_kind": "clone"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "reference_kind_mismatch",
            "phase": "schema_validation",
            "span": [0, 12]
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-005",
      "description": "reference=forbid rejects clone references at a constrained path",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "CloneReference",
              "path": ["target"],
              "span": [4, 11]
            },
            "span": [0, 11]
          }
        ],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "forbid"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "reference_forbidden",
            "phase": "schema_validation",
            "span": [0, 11]
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-006",
      "description": "reference_kind without reference=require is invalid schema",
      "input": {
        "aes": [],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference_kind": "clone"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "invalid_reference_constraint",
            "phase": "schema_validation",
            "span": null
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-007",
      "description": "schema reference_policy=forbid conflicts with rules that require references",
      "input": {
        "aes": [],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "require"
              }
            }
          ],
          "reference_policy": "forbid"
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "path": "$.x",
            "code": "invalid_reference_constraint",
            "phase": "schema_validation",
            "span": null
          }
        ],
        "warnings": [],
        "guarantees": {}
      }
    },
    {
      "id": "reference-form-008",
      "description": "Missing reference targets remain Core-owned even when reference=require passes",
      "input": {
        "aes": [
          {
            "path": {
              "segments": [
                { "type": "root" },
                { "type": "member", "key": "x" }
              ]
            },
            "key": "x",
            "value": {
              "type": "CloneReference",
              "path": ["missing"],
              "span": [4, 12]
            },
            "span": [0, 12]
          }
        ],
        "schema": {
          "rules": [
            {
              "path": "$.x",
              "constraints": {
                "reference": "require",
                "reference_kind": "clone"
              }
            }
          ]
        }
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "guarantees": {}
      }
    }
  ]
}
