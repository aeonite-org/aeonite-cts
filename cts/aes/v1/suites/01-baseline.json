    {
      "id": "aes-baseline-013-generic-depth-override-pass",
      "description": "Raised max_generic_depth emits nested generic datatype annotations deterministically",
      "input": {
        "source": "t:tuple<tuple<n, n>, tuple<n, n>> = ((1,2),(1,2))",
        "mode": "strict",
        "options": {
          "max_generic_depth": 8
