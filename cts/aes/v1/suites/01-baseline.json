      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "aes-baseline-008-separator-short-alias-emits-separator-value",
      "description": "Strict mode emits sep as a reserved separator alias",
      "input": {
        "source": "aeon:mode = \"strict\"\nparts:sep[|] = ^a|b",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.parts",
              "datatype": "sep[|]",
              "value_kind": "SeparatorLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "separator"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md#34-separator-literal"
      ]
    },
    {
      "id": "aes-baseline-009-stale-radix-alias-reject",
      "description": "Strict mode treats stale radix aliases like radix16 as custom datatypes at the AES boundary",
      "input": {
        "source": "aeon:mode = \"strict\"\nclock:radix16 = %BEEF",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "CUSTOM_DATATYPE_NOT_ALLOWED",
