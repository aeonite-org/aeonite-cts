    },
    {
      "id": "aes-baseline-010-separator-depth-default-reject",
      "description": "Default max_separator_depth rejects chained separator specs before AES emission",
      "input": {
        "source": "matrix:grid[|][/] = ^1|2/3",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SEPARATOR_DEPTH_EXCEEDED",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "events": []
        }
      },
      "tags": ["baseline", "depth-policy", "separator", "fail"],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/AEON-v1-compliance.md#5-depth-policy-requirements"
      ]
    },
    {
      "id": "aes-baseline-011-separator-depth-override-pass",
      "description": "Raised max_separator_depth emits chained separator specs deterministically",
      "input": {
        "source": "matrix:grid[|][/] = ^1|2/3",
        "mode": "strict",
        "options": {
          "max_separator_depth": 8
        }
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
