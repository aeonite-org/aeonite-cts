      ]
    },
    {
      "id": "aes-baseline-012-generic-depth-default-reject",
      "description": "Default max_generic_depth rejects nested generic datatype annotations before AES emission",
      "input": {
        "source": "t:tuple<tuple<n, n>, tuple<n, n>> = ((1,2),(1,2))",
