            {
              "path": "$.t[0][0]",
              "datatype": null,
              "value_kind": "NumberLiteral",
              "reference": null
            },
            {
              "path": "$.t[0][1]",
              "datatype": null,
              "value_kind": "NumberLiteral",
              "reference": null
            },
            {
              "path": "$.t[1]",
              "datatype": null,
              "value_kind": "TupleLiteral",
              "reference": null
            },
            {
              "path": "$.t[1][0]",
              "datatype": null,
              "value_kind": "NumberLiteral",
              "reference": null
            },
            {
              "path": "$.t[1][1]",
              "datatype": null,
              "value_kind": "NumberLiteral",
              "reference": null
