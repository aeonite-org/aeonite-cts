{
  "meta": {
    "suite_id": "baseline",
    "lane": "aes",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/appendices/appendix-aes.md"
    ]
  },
  "id": "baseline",
  "title": "AES Baseline Emission",
  "tests": [
    {
      "id": "aes-baseline-001",
      "description": "Single assignment emits one normalized event",
      "input": {
        "source": "a:number = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.a",
              "datatype": "number",
              "value_kind": "NumberLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md"
      ]
    },
    {
      "id": "aes-baseline-002",
      "description": "Forward reference fails at AES validation boundary",
      "input": {
        "source": "b = ~a\na = 1",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "FORWARD_REFERENCE",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "events": []
        }
      },
      "tags": [
        "baseline",
        "emission-fail"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#10-references"
      ]
    },
    {
      "id": "aes-baseline-003-envelope-alias-emits-object-node",
      "description": "Strict mode emits envelope-typed bindings as ObjectNode values",
      "input": {
        "source": "aeon:mode = \"strict\"\nclose:envelope = { hash:string = \"abc\" }",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.close",
              "datatype": "envelope",
              "value_kind": "ObjectNode",
              "reference": null
            },
            {
              "path": "$.close.hash",
              "datatype": "string",
              "value_kind": "StringLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "envelope"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "aes-baseline-004-time-literal-emits-time-value",
      "description": "Strict mode emits typed time literals with reserved datatype",
      "input": {
        "source": "aeon:mode = \"strict\"\nopens:time = 09:30:00Z",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.opens",
              "datatype": "time",
              "value_kind": "TimeLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "time"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "aes-baseline-004b-radix12-alias-emits-radix-value",
      "description": "Strict mode emits radix12 as a reserved radix alias",
      "input": {
        "source": "aeon:mode = \"strict\"\nclock:radix12 = %AB10",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.clock",
              "datatype": "radix12",
              "value_kind": "RadixLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "radix"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md#36-radix"
      ]
    },
    {
      "id": "aes-baseline-005-strict-removed-separator-alias-reject",
      "description": "Strict mode treats removed separator aliases like dim[...] as custom datatypes at the AES boundary",
      "input": {
        "source": "aeon:mode = \"strict\"\nsize:dim[x] = ^1920x1080",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "CUSTOM_DATATYPE_NOT_ALLOWED",
            "path": "$.size",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "events": []
        }
      },
      "tags": [
        "baseline",
        "emission-fail",
        "removed-alias"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "aes-baseline-006-strict-removed-separator-alias-allow-custom-pass",
      "description": "Strict mode emits removed separator aliases when datatype policy is allow_custom",
      "input": {
        "source": "aeon:mode = \"strict\"\nsize:dim[x] = ^1920x1080",
        "mode": "strict",
        "options": {
          "datatype_policy": "allow_custom"
        }
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.size",
              "datatype": "dim[x]",
              "value_kind": "SeparatorLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "removed-alias"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "aes-baseline-006b-strict-header-payload-untyped-reject",
      "description": "Strict mode rejects untyped structured header payload bindings at the AES boundary",
      "input": {
        "source": "aeon:header = {\n  mode = \"strict\"\n  meta = {\n    document:string = \"public\"\n  }\n}",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "UNTYPED_VALUE_IN_STRICT_MODE",
            "path": "$[\"aeon:meta\"]",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "events": []
        }
      },
      "tags": [
        "baseline",
        "emission-fail",
        "header",
        "typing"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/AEON-v1-compliance.md#7-strict-mode-requirements"
      ]
    },
    {
      "id": "aes-baseline-006c-strict-header-payload-typed-pass",
      "description": "Strict mode emits typed structured header payload bindings and nested members",
      "input": {
        "source": "aeon:header = {\n  mode = \"strict\"\n  meta:object = {\n    document:string = \"public\"\n  }\n}",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$[\"aeon:meta\"].document",
              "datatype": "string",
              "value_kind": "StringLiteral",
              "reference": null
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "emission-pass",
        "header",
        "typing"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/AEON-v1-compliance.md#7-strict-mode-requirements"
      ]
    },
    {
      "id": "aes-baseline-006d-late-structured-header-reject",
      "description": "Structured headers are rejected when they appear after body bindings before AES emission",
      "input": {
        "source": "app:object = {\n  name:string = \"playground\"\n}\naeon:header = {\n  mode:string = \"strict\"\n}",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "events": []
        }
      },
      "tags": [
        "baseline",
        "emission-fail",
        "header",
        "ordering"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-aes.md",
        "specs/04-official/v1/AEON-spec-v1.md#10-phase-boundaries"
      ]
    },
    {
      "id": "aes-baseline-007-object-short-alias-emits-object-node",
      "description": "Strict mode emits obj-typed bindings as ObjectNode values",
      "input": {
        "source": "aeon:mode = \"strict\"\npayload:obj = { a:number = 1 }",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "events": [
            {
              "path": "$.payload",
              "datatype": "obj",
              "value_kind": "ObjectNode",
              "reference": null
