{
  "meta": {
    "suite_id": "baseline",
    "lane": "canonical",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/AEON-spec-v1.md"
    ]
  },
  "id": "baseline",
  "title": "Canonical Baseline Formatting",
  "tests": [
    {
      "id": "canonical-baseline-001-header-binding-preservation",
      "description": "Structured header bindings follow normal canonical binding rules",
      "input": {
        "source": "aeon:header = {\n  ':' = \"hello\"\n  mode:number = \"strict\"\n  a = { c:n = 0}\n  b@{a:n=2} = 2\n  n:node = <a(<a(<a@{g:string=\"h\"}()>)>)>\n}"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  \":\" = \"hello\"\n  a = {\n    c:n = 0\n  }\n  b@{a:n = 2} = 2\n  mode:number = \"strict\"\n  n:node = <a(\n    <a(\n      <a@{g:string = \"h\"}>\n    )>\n  )>\n}"
        }
      },
      "tags": [
        "baseline",
        "header",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "canonical-baseline-002-list-indentation",
      "description": "Multiline list items retain canonical indentation",
      "input": {
        "source": "a = [\n  1,\n  { b = 2 },\n  [3, 4]\n]"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\na = [\n  1,\n  {\n    b = 2\n  },\n  [\n    3,\n    4\n  ]\n]"
        }
      },
      "tags": [
        "baseline",
        "lists",
        "indentation"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "canonical-baseline-003-nested-node-attribute-inline",
      "description": "Nested node attribute values are not truncated in canonical output",
      "input": {
        "source": "d@{\n  n = <a(<a(<a()>)>)>\n}:string = \"hello\""
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nd@{n = <a(<a(<a>)>)>}:string = \"hello\""
        }
      },
      "tags": [
        "baseline",
        "attributes",
        "nodes"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "canonical-baseline-004-syntax-reject",
      "description": "Malformed input fails with deterministic syntax diagnostics",
      "input": {
        "source": "a = {"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {}
      },
      "tags": [
        "baseline",
        "reject"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "canonical-baseline-005-late-structured-header-reject",
      "description": "Structured headers must appear before body bindings and are rejected in canonical formatting when they appear later",
      "input": {
        "source": "app:object = {\n  name:string = \"playground\"\n}\naeon:header = {\n  mode:string = \"strict\"\n}"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {}
      },
      "tags": [
        "baseline",
        "header",
        "reject"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "canonical-baseline-006-file-preamble-does-not-leak",
      "description": "Shebang and host format directive are file-header trivia and do not appear in canonical output",
      "input": {
        "source": "#!/usr/bin/env aeon\n//! format:aeon.test.v1\nvalue:number = 1"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nvalue:number = 1"
        }
      },
      "tags": [
        "baseline",
        "comments",
        "shebang",
        "format-directive"
      ],
      "spec_refs": [
        "specs/04-official/v1/comments-annotations-v1.md#25-host-channel",
        "specs/04-official/v1/AEON-v1-compliance.md#6-comment-and-annotation-requirements"
      ]
    },
    {
      "id": "canonical-baseline-007-leading-bom-file-preamble-does-not-leak",
      "description": "A single leading UTF BOM is ignored and does not appear in canonical output",
      "input": {
        "source": "﻿#!/usr/bin/env aeon\n//! format:aeon.test.v1\nvalue:number = 1"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nvalue:number = 1"
        }
      },
      "tags": [
        "baseline",
        "comments",
        "bom",
        "shebang",
        "format-directive"
      ],
      "spec_refs": [
        "specs/04-official/v1/comments-annotations-v1.md#25-host-channel",
        "specs/04-official/v1/AEON-v1-compliance.md#6-comment-and-annotation-requirements"
      ]
    },
    {
      "id": "canonical-baseline-008-radix-underscores-strip-in-canonical-output",
      "description": "Radix literals canonicalize without underscore separators while preserving the remaining digit sequence",
      "input": {
        "source": "aeon:mode = \"transport\"\nmask:radix = %101_0101"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  mode = \"transport\"\n}\nmask:radix = %1010101"
        }
      },
      "tags": [
        "baseline",
        "radix",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#37-radix"
      ]
    },
    {
      "id": "canonical-baseline-009-encoding-literals-prefer-url-safe-base64",
      "description": "Encoding literals canonicalize to the URL-safe base64 alphabet and omit trailing padding",
      "input": {
        "source": "aeon:mode = \"transport\"\npayload:base64 = $+///=="
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  mode = \"transport\"\n}\npayload:base64 = $-___"
        }
      },
      "tags": [
        "baseline",
        "encoding",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#38-encoding"
      ]
    },
    {
      "id": "canonical-baseline-010-number-family-normalization",
      "description": "Number canonicalization is value-normalizing while preserving integer, decimal, and exponent families",
      "input": {
        "source": "plain:number = +10\nfraction:number = 10.00\nhalf:number = +.5\nscientific:number = 1.0E+03"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nfraction:number = 10.0\nhalf:number = 0.5\nplain:number = 10\nscientific:number = 1e3"
        }
      },
      "tags": [
        "baseline",
        "numbers",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#33-number",
        "specs/04-official/v1/appendices/appendix-canonical-form-v1.md#scalars"
      ]
    },
    {
      "id": "canonical-baseline-011-zero-family-normalization",
      "description": "Zero canonicalization follows the same integer, decimal, and exponent family model",
      "input": {
        "source": "a:number = +0\nb:number = -.0\nc:number = 0.0e+0\nd:number = -0.0E-0"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\na:number = 0\nb:number = -0.0\nc:number = 0e0\nd:number = -0e0"
        }
      },
      "tags": [
        "baseline",
        "numbers",
        "zero",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#33-number",
        "specs/04-official/v1/appendices/appendix-canonical-form-v1.md#scalars"
      ]
    },
    {
      "id": "canonical-baseline-012-radix-representation-preserving",
      "description": "Radix canonicalization strips separators but otherwise preserves the represented digit sequence and decimal layout",
      "input": {
        "source": "aeon:mode = \"transport\"\nmask:radix[10] = %10.00\nwidth:radix[10] = %0010.00\nbits:radix[2] = %10_10"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  mode = \"transport\"\n}\nbits:radix[2] = %1010\nmask:radix[10] = %10.00\nwidth:radix[10] = %0010.00"
        }
      },
      "tags": [
        "baseline",
        "radix",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#37-radix",
        "specs/04-official/v1/appendices/appendix-canonical-form-v1.md#scalars"
      ]
    },
    {
      "id": "canonical-baseline-013-nan-preserves-lexeme",
      "description": "NaN literals canonically preserve NaN and -NaN exactly",
      "input": {
        "source": "top:nan = NaN\nbottom:nan = -NaN"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nbottom:nan = -NaN\ntop:nan = NaN"
        }
      },
      "tags": [
        "baseline",
        "nan",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#332-nan"
      ]
    },
    {
      "id": "canonical-baseline-014-null-preserves-family-boundary",
      "description": "Null canonicalization preserves the reserved-sentinel versus quoted-reason family distinction",
      "input": {
        "source": "top:null = !none\nbottom:null = !'postponed'"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nbottom:null = !\"postponed\"\ntop:null = !none"
        }
      },
      "tags": [
        "baseline",
        "null",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#333-null"
      ]
    },
    {
      "id": "canonical-baseline-015-null-comment-boundary-preserved",
      "description": "Canonicalization strips trailing comments from reserved null literals without folding them into the sentinel token",
      "input": {
        "source": "aeon:mode = \"strict\"\nn10:null = !none//Null"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  mode = \"strict\"\n}\nn10:null = !none"
        }
      },
      "tags": [
        "baseline",
        "null",
        "comments",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/value-types-v1.md#333-null",
        "specs/04-official/v1/structure-syntax-v1.md"
      ]
    },
    {
      "id": "canonical-baseline-016-reference-whitespace-after-sigil-normalized",
      "description": "Canonicalization removes inter-token whitespace between clone or pointer sigils and the following reference path",
      "input": {
        "source": "order:o = {\n  total:n = 2\n}\nclone:n = ~ order.total\npointer:n = ~> order.total"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "canonical_text": "aeon:header = {\n  encoding = \"utf-8\"\n  mode = \"transport\"\n  profile = \"core\"\n  version = 1.0\n}\nclone:n = ~order.total\norder:o = {\n  total:n = 2\n}\npointer:n = ~>order.total"
        }
      },
      "tags": [
        "baseline",
        "references",
        "whitespace",
        "formatting"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/addressing-references-v1.md",
        "specs/04-official/v1/value-types-v1.md"
      ]
    }
  ]
}
