{
  "meta": {
    "suite_id": "promoted-snippet-transport",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/addressing-references-v1.md",
      "specs/04-official/v1/structure-syntax-v1.md"
    ]
  },
  "id": "promoted-snippet-transport",
  "title": "Promoted Deterministic Snippet Transport Cases",
  "tests": [
    {
      "id": "core-snippet-transport-001-quoted-key-clone-reference",
      "description": "Quoted-key clone references preserve single-key traversal rather than dotted descent",
      "input": {
        "source": "a = { \"b.c\" = 1 }\nv = ~a.[\"b.c\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.a.[\"b.c\"]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "snippets",
        "transport",
        "quoted-keys",
        "references"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-002-quoted-attribute-segment-reference",
      "description": "Quoted segments after attribute traversal remain valid clone-reference targets in transport mode",
      "input": {
        "source": "a@{ meta = { \"x.y\" = 1 } } = 3\nv = ~a@meta.[\"x.y\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "snippets",
        "transport",
        "attributes",
        "references"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-003-empty-quoted-keys-reject",
      "description": "Empty quoted keys reject both as object keys and as quoted reference segments",
      "input": {
        "source": "a = { \"\" = 1 }\nv = ~a.[\"\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          },
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "references",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md",
        "specs/04-official/v1/structure-syntax-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-004-attribute-segment-required",
      "description": "Bare trailing attribute markers reject without a following attribute path segment",
      "input": {
        "source": "a = 1\nv = ~a@\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "attributes",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-005-leading-segment-required",
      "description": "Quoted traversal segments reject when no leading path segment is present",
      "input": {
        "source": "a = 1\nv = ~.[\"a\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "references",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-006-attribute-depth-max-enforced",
      "description": "Attribute traversal beyond the allowed depth rejects during reference validation",
      "input": {
        "source": "a@{ meta = 1 } = 3\nv = ~a@meta@[\"x\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "ATTRIBUTE_DEPTH_EXCEEDED",
            "phaseLabel": "Reference Validation"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "attributes",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-007-missing-reference-target-rejects",
      "description": "Quoted traversal to a missing nested target rejects during reference validation",
      "input": {
        "source": "a = { b = 1 }\nv = ~a.[\"b\"].[\"c\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "MISSING_REFERENCE_TARGET",
            "phaseLabel": "Reference Validation"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "references",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-008-typed-generic-custom-containers-pass",
      "description": "Transport mode still accepts explicitly typed generic custom datatypes over list and tuple containers",
      "input": {
        "source": "b:custom<custom> = [2]\nc:custom<custom> = (2)\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.b",
              "datatype": "custom<custom>",
              "kind": "binding"
            },
            {
              "path": "$.b[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.c",
              "datatype": "custom<custom>",
              "kind": "binding"
            },
            {
              "path": "$.c[0]",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "snippets",
        "transport",
        "custom-datatypes",
        "containers"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#8-behavior-modes-and-datatype-policy",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-009-typed-bracketed-custom-literals-pass",
      "description": "Transport mode still accepts explicitly typed bracketed custom datatypes over valid radix and separator literal families",
      "input": {
        "source": "f:custom[2] = %10101\ng:custom[.] = ^1.1.1\nh:custom[1] = ^1.1.1\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.f",
              "datatype": "custom[2]",
              "kind": "binding"
            },
            {
              "path": "$.g",
              "datatype": "custom[.]",
              "kind": "binding"
            },
            {
              "path": "$.h",
              "datatype": "custom[1]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "snippets",
        "transport",
        "custom-datatypes",
        "separator",
        "radix"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#8-behavior-modes-and-datatype-policy",
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-010-malformed-bare-number-tail-rejects",
      "description": "Bare transport literals that continue with a hyphen-digit tail reject as invalid numbers rather than reaching finalize",
      "input": {
        "source": "a = 1-1\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "INVALID_NUMBER",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "numbers",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md",
        "specs/04-official/v1/structure-syntax-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-011-incomplete-exponent-number-rejects",
      "description": "Incomplete exponent spellings reject as invalid numbers in transport mode",
      "input": {
        "source": "a = 1e\nb = 1e+\nc = 1e-\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "INVALID_NUMBER",
            "phaseLabel": "Lexing"
          },
          {
            "code": "INVALID_NUMBER",
            "phaseLabel": "Lexing"
          },
          {
            "code": "INVALID_NUMBER",
            "phaseLabel": "Lexing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "numbers",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-012-non-zero-padded-date-candidates-reject",
      "description": "Transport mode rejects date-like literals whose month or day segments are not zero-padded",
      "input": {
        "source": "a = 0000-1-20\nb = 0000-02-1\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "INVALID_DATE",
            "phaseLabel": "Parsing"
          },
          {
            "code": "INVALID_DATE",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "dates",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-snippet-transport-013-single-digit-hour-time-candidate-rejects",
      "description": "Transport mode rejects single-digit hour time candidates with a temporal-specific invalid-time diagnostic",
      "input": {
        "source": "a = 9:00\n",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "INVALID_TIME",
            "phaseLabel": "Lexing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "snippets",
        "transport",
        "time",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    }
  ]
}
