{
  "meta": {
    "suite_id": "attributes-and-references",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/appendices/appendix-addressing.md",
      "specs/04-official/v1/AEON-spec-v1.md#10-references"
    ]
  },
  "id": "attributes-and-references",
  "title": "Core Attributes and Reference Semantics",
  "tests": [
    {
      "id": "core-attr-001-clone-reference-pass",
      "description": "Attribute clone reference parses and emits binding in strict mode",
      "input": {
        "source": "a@{ns=\"alto.v1\"} = 1\nv = ~a@ns",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references"],
      "spec_refs": ["specs/04-official/v1/appendices/appendix-addressing.md"]
    },
    {
      "id": "core-attr-002-missing-target",
      "description": "Missing attribute reference target is rejected deterministically",
      "input": {
        "source": "a = 1\nv = ~a@ns",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "MISSING_REFERENCE_TARGET",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "references", "fail"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-003-forward-target",
      "description": "Forward attribute reference target is rejected",
      "input": {
        "source": "v = ~a@ns\na@{ns=\"alto.v1\"} = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "FORWARD_REFERENCE",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "references", "fail"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-004-depth-exceeded",
      "description": "Chained attribute reference beyond default depth lock is rejected",
      "input": {
        "source": "a@{b=2} = 1\nv = ~a@b@c",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "ATTRIBUTE_DEPTH_EXCEEDED",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "references", "depth-policy", "fail"],
      "spec_refs": ["specs/04-official/v1/appendices/appendix-addressing.md"]
    },
    {
      "id": "core-attr-004a-nested-attribute-head-depth-exceeded",
      "description": "Nested attribute heads count against the default max_attribute_depth limit",
      "input": {
        "source": "a@{b@{c=3}=2} = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "ATTRIBUTE_DEPTH_EXCEEDED",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "depth-policy", "fail"],
      "spec_refs": ["specs/04-official/v1/appendices/appendix-addressing.md"]
    },
    {
      "id": "core-attr-004b-depth-override-pass",
      "description": "Chained attribute reference is accepted when max_attribute_depth is raised",
      "input": {
        "source": "a@{b@{c=3}=2} = 1\nv = ~a@b@c",
        "mode": "strict",
        "options": {
          "max_attribute_depth": 8
        }
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "depth-policy", "override"],
      "spec_refs": ["specs/04-official/v1/appendices/appendix-addressing.md"]
    },
    {
      "id": "core-attr-004c-duplicate-attribute-key-reject",
      "description": "Duplicate keys inside one attribute map are rejected fail closed",
      "input": {
        "source": "a@{x=1, x=2} = 3",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DUPLICATE_KEY",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "duplicates", "fail"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-attr-004d-repeated-attribute-entry-head-reject",
      "description": "Repeated attribute heads on one attribute entry are rejected even when nested attribute depth is raised",
      "input": {
        "source": "a@{x@{y=1}@{z=2} = 3} = 4",
        "mode": "strict",
        "options": {
          "max_attribute_depth": 8
        }
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "syntax", "duplicates", "fail"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-attr-005-mixed-path-after-attribute-pass",
      "description": "Quoted bracket member segment is accepted after attribute selector",
      "input": {
        "source": "a@{meta = { \"x.y\" = 1 }} = 0\nv = ~a@meta.[\"x.y\"]",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "mixed-path"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    },
    {
      "id": "core-attr-006-nested-binding-attribute-reference-pass",
      "description": "Nested binding attributes inside containers remain addressable",
      "input": {
        "source": "a = [{x@{b=0}=1}]\nv = ~a[0].x@b",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.a[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.a[0].x",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.v",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "nested"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    },
    {
      "id": "core-attr-006b-nested-binding-same-object-reference-pass",
      "description": "A nested binding may reference an earlier sibling within the same object without being treated as a parent forward reference",
      "input": {
        "source": "a:o = {\n  a:string = \"hello\"\n  b:string = ~a.a\n}",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": "o",
              "kind": "binding"
            },
            {
              "path": "$.a.a",
              "datatype": "string",
              "kind": "binding"
            },
            {
              "path": "$.a.b",
              "datatype": "string",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "nested", "regression"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    },
    {
      "id": "core-attr-007-postfix-literal-attributes-reject",
      "description": "Postfix literal attributes are not valid Core v1 syntax",
      "input": {
        "source": "a = [0]@{b=2}",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "syntax", "fail"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-attr-007a-floating-object-attributes-reject",
      "description": "Object attributes must be attached to the object binding or to an object member binding",
      "input": {
        "source": "x = { @{meta=1} k = 2 }",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "objects", "syntax", "fail", "regression"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-attr-008-binding-payload-may-reference-own-attribute-pass",
      "description": "A binding payload may reference one of its own attached attributes",
      "input": {
        "source": "a@{x=1} = ~a@x",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-009-attribute-payload-self-payload-reject",
      "description": "An attribute payload may not reference the payload of its own binding",
      "input": {
        "source": "a@{x=~a} = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SELF_REFERENCE",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "references", "fail", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-010-attribute-payload-forward-binding-reject",
      "description": "An attribute payload may not reference a later payload binding",
      "input": {
        "source": "a@{x=~b} = 1\nb = 2",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "FORWARD_REFERENCE",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["attributes", "references", "fail", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-011-direct-sequence-item-backward-pass",
      "description": "Direct sequence items may reference earlier sibling items by index",
      "input": {
        "source": "items = [1, ~items[0]]",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.items",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.items[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.items[1]",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["references", "lists", "tuples", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-011b-initial-quoted-member-shorthand-pass",
      "description": "Initial quoted member shorthand is equivalent to bracketed quoted-member traversal",
      "input": {
        "source": "\"a.b\":list = [1, 2]\nb:n = ~\"a.b\"[1]",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.[\"a.b\"]",
              "datatype": "list",
              "kind": "binding"
            },
            {
              "path": "$.[\"a.b\"][0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.[\"a.b\"][1]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.b",
              "datatype": "n",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["references", "quoted-keys", "indexes", "regression"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    },
    {
      "id": "core-attr-011a-typed-sequence-item-backward-pass",
      "description": "Typed list and tuple items may reference earlier sibling items by index",
      "input": {
        "source": "c:list = [1, 1, ~c[0]]\nd:tuple = (1, 1, ~d[0])",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.c",
              "datatype": "list",
              "kind": "binding"
            },
            {
              "path": "$.c[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.c[1]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.c[2]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.d",
              "datatype": "tuple",
              "kind": "binding"
            },
            {
              "path": "$.d[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.d[1]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.d[2]",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["references", "lists", "tuples", "typed", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-012-direct-sequence-item-forward-reject",
      "description": "Direct sequence items may not reference later sibling items by index",
      "input": {
        "source": "items = [~items[1], 1]",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "FORWARD_REFERENCE",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": ["references", "lists", "tuples", "fail", "regression"],
      "spec_refs": ["specs/04-official/v1/AEON-spec-v1.md#10-references"]
    },
    {
      "id": "core-attr-013-escaped-decoded-identity-pointers-pass",
      "description": "Pointer references resolve through escaped-decoded quoted member and attribute traversal",
      "input": {
        "source": "#!/bin/aeon --profile=ts.object.v1\n\naeon:header = {\n  version = \"1.0\"\n  mode = \"transport\"\n  profile = \"ts.object.v1\"\n}\n\n\"aA\":int32 = 1\nptrTop = ~>[\"a\\u0041\"]\n\nobj = {\n  \"bA\":int32 = 2\n}\nptrNested = ~>obj.[\"b\\u0041\"]\n\nhost@{\n  \"xA\":int32 = 3\n} = 4\nptrAttr = ~>host@[\"x\\u0041\"]\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.[\"aA\"]",
              "datatype": "int32",
              "kind": "binding"
            },
            {
              "path": "$.ptrTop",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.obj",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.obj.[\"bA\"]",
              "datatype": "int32",
              "kind": "binding"
            },
            {
              "path": "$.ptrNested",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.host",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.ptrAttr",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "unicode", "pointers"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    },
    {
      "id": "core-attr-014-escaped-decoded-identity-rooted-clones-pass",
      "description": "Rooted and chained clone references resolve through escaped-decoded quoted traversal",
      "input": {
        "source": "#!/bin/aeon --profile=ts.object.v1\n\naeon:header = {\n  version = \"1.0\"\n  mode = \"transport\"\n  profile = \"ts.object.v1\"\n}\n\n\"aA\":int32 = 1\nrootClone = ~$.[\"a\\u0041\"]\n\nobj = {\n  \"bA\":int32 = 2\n}\nrootNested = ~$.obj.[\"b\\u0041\"]\n\nhost@{\n  \"xA\":int32 = 3\n} = 4\nrootAttr = ~$.host@[\"x\\u0041\"]\n\nchain1 = ~[\"a\\u0041\"]\nchain2 = ~chain1\n",
        "mode": "transport"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.[\"aA\"]",
              "datatype": "int32",
              "kind": "binding"
            },
            {
              "path": "$.rootClone",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.obj",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.obj.[\"bA\"]",
              "datatype": "int32",
              "kind": "binding"
            },
            {
              "path": "$.rootNested",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.host",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.rootAttr",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.chain1",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.chain2",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": ["attributes", "references", "unicode", "rooted"],
      "spec_refs": ["specs/04-official/v1/addressing-references-v1.md"]
    }
  ]
}
