{
  "meta": {
    "suite_id": "promoted-edge-rejections",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/comments-annotations-v1.md",
      "specs/04-official/v1/structure-syntax-v1.md",
