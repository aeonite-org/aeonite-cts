{
  "meta": {
    "suite_id": "promoted-edge-rejections",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/comments-annotations-v1.md",
      "specs/04-official/v1/structure-syntax-v1.md",
      "specs/04-official/v1/appendices/appendix-error-model.md"
    ]
  },
  "id": "promoted-edge-rejections",
  "title": "Promoted Deterministic Edge Rejections",
  "tests": [
    {
      "id": "core-edge-001-unterminated-block-comment-rejects",
      "description": "An unterminated block comment fails closed with a deterministic lexical error",
      "input": {
        "source": "//!/bin/aeon --profile=ts.object.v1\n\n/# Comment Stress (r5 target forms) #/\naeon:header = {\n  version = \"2.1\"\n  mode = \"transport\"\n  profile = \"ts.object.v1\"\n}\n\n//# line doc\n/# block doc #/\na:int32 = 1 //? line hint\n/? block hint ?/\n\n//@ line annotation\n/@ block annotation @/\nb:int32 = 2\n\n//{ line structure\n/{ block structure }/\n\n//[ line profile\n/[ block profile ]/\n\n//( line instructions\n/( block instructions )/\n\n// plain line comment\n/* plain block comment */\n\nlist:list<int32> = [\n  1 /# postfix element doc #/\n  /# prefix element doc #/ 2\n  3\n]\n\nmixed = ~ /? reference hint ?/ list[1]\n\n/# block doc for container #/\nemptyList:list<int32> = [ /# container fallback #/ ]\n\n/? orphan eof\n"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "UNTERMINATED_BLOCK_COMMENT",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "comments",
        "lexical"
      ],
      "spec_refs": [
        "specs/04-official/v1/comments-annotations-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-edge-002-separator-invalid-raw-chars-reject",
      "description": "Separator literals fail closed when raw payloads rely on characters that are only legal inside quoted segments",
      "input": {
        "source": "badSlash:sep[/] = ^root/main/file.aeon\nbadSpace:sep[|] = ^aaa bbb\n"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "separators",
        "lexical"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-edge-003-separator-unterminated-quoted-segment-rejects",
      "description": "Separator literals fail closed on unterminated quoted payload segments",
      "input": {
        "source": "badQuote:sep[|] = ^\"hello\n"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "UNTERMINATED_STRING",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "separators",
        "lexical"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    }
  ]
}
