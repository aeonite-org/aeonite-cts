{
  "meta": {
    "suite_id": "promoted-separator-literals",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/value-types-v1.md",
      "specs/04-official/v1/structure-syntax-v1.md"
    ]
  },
  "id": "promoted-separator-literals",
  "title": "Promoted Deterministic Separator Literal Cases",
  "tests": [
    {
      "id": "core-sep-001-raw-whitelist-payload-accepted",
      "description": "Separator literals accept raw payloads built only from the separator raw-character whitelist",
      "input": {
        "source": "size:sep[x] = ^300x250\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.size",
              "datatype": "sep[x]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "separator",
        "literals"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-002-quoted-segments-accepted",
      "description": "Separator literals accept ordinary quoted string segments for payload content that falls outside the raw whitelist",
      "input": {
        "source": "parts:sep[|] = ^\"hello world\"|\"this, [is] fine\"\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.parts",
              "datatype": "sep[|]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "separator",
        "literals"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-003-raw-slash-payload-rejects",
      "description": "Raw separator payloads reject slash characters unless they appear inside quoted segments",
      "input": {
        "source": "file:sep[/] = ^root/main/file.aeon\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "separator",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-004-raw-comma-payload-rejects",
      "description": "Raw separator payloads reject comma characters unless they appear inside quoted segments",
      "input": {
        "source": "coords:sep[|] = ^1,2,3\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "separator",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-005-unparameterized-sep-rejects-caret-literal",
      "description": "Using a caret separator literal against an unparameterized sep datatype rejects with a syntax error",
      "input": {
        "source": "blue:sep = ^200\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "separator",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-006-separator-datatype-rejects-list-node",
      "description": "A sep-typed binding rejects list literals even when the list contains a separator literal",
      "input": {
        "source": "filex:sep[/] = [^\"root/main/file.aeon\"]\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DATATYPE_LITERAL_MISMATCH",
            "phaseLabel": "Core Validation"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "separator",
        "validation",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-sep-007-unterminated-quoted-segment-rejects",
      "description": "Separator literals reject quoted payload segments that do not terminate before the line ends",
      "input": {
        "source": "bad:sep[|] = ^\"hello\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "UNTERMINATED_STRING"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "separator",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md",
        "specs/04-official/v1/structure-syntax-v1.md"
      ]
    }
  ]
}
