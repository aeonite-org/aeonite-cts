{
  "meta": {
    "suite_id": "fail-closed-semantics",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/AEON-spec-v1.md",
      "specs/04-official/v1/appendices/appendix-error-model.md",
      "specs/04-official/v1/addressing-references-v1.md"
    ]
  },
  "id": "fail-closed-semantics",
  "title": "Core Fail-Closed Semantic Guarantees",
  "tests": [
    {
      "id": "core-semantics-001-duplicate-key-fail-closed",
      "description": "Duplicate keys in one document are rejected and emit no bindings in fail-closed mode",
      "input": {
        "source": "a = 1\na = 2",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DUPLICATE_KEY",
            "path": "$.a",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "duplicates",
        "keys"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-semantics-001a-duplicate-object-member-key-fail-closed",
      "description": "Duplicate object member keys are rejected and emit no bindings in fail-closed mode",
      "input": {
        "source": "config = { a = 1, a = 2 }",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DUPLICATE_KEY",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "duplicates",
        "keys",
        "objects"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-semantics-002-header-conflict-fail-closed",
      "description": "Structured header and shorthand header bindings cannot be mixed",
      "input": {
        "source": "aeon:header = { profile = \"core\" }\naeon:mode = \"strict\"\na:int32 = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "HEADER_CONFLICT",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "headers",
        "strict"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-semantics-003-strict-untyped-switch-fail-closed",
      "description": "Strict mode requires switch literals to be explicitly typed",
      "input": {
        "source": "aeon:mode = \"strict\"\ndebug = yes",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "UNTYPED_SWITCH_LITERAL",
            "path": "$.debug",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "strict",
        "switch"
      ],
      "spec_refs": [
        "specs/04-official/v1/appendices/appendix-error-model.md",
        "specs/04-official/v1/AEON-v1-compliance.md#7-strict-mode-requirements"
      ]
    },
    {
      "id": "core-semantics-004-escaped-decoded-identity-duplicate-key-fail-closed",
      "description": "Escaped and decoded-equivalent keys are rejected fail closed as duplicate keys",
      "input": {
        "source": "aA = 1\n\"a\\u0041\" = 2\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DUPLICATE_KEY",
            "path": "$.aA",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "fail-closed",
        "duplicates",
        "keys",
        "unicode"
      ],
      "spec_refs": [
        "specs/04-official/v1/addressing-references-v1.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    }
  ]
}
