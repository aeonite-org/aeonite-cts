    },
    {
      "id": "core-numenc-008-invalid-number-rejects",
      "description": "Malformed underscored exponent number literals reject during parsing",
      "input": {
        "source": "a:number = 1e_2\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "INVALID_NUMBER"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "numbers",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-009-invalid-base64-class-rejects",
      "description": "Invalid base64 literal spellings reject as datatype and literal-class mismatches",
      "input": {
        "source": "payload:base64 = $abc.\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "DATATYPE_LITERAL_MISMATCH",
            "phaseLabel": "Core Validation"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "base64",
        "rejection"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
