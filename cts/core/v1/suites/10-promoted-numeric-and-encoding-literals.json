{
  "meta": {
    "suite_id": "promoted-numeric-and-encoding-literals",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/value-types-v1.md",
      "specs/04-official/v1/structure-syntax-v1.md"
    ]
  },
  "id": "promoted-numeric-and-encoding-literals",
  "title": "Promoted Deterministic Numeric and Encoding Literal Cases",
  "tests": [
    {
      "id": "core-numenc-001-underscored-exponent-number-accepted",
      "description": "Underscored exponent number spellings remain accepted in strict typed bindings",
      "input": {
        "source": "a:number = 1_1_1e2_2\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": "number",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "numbers",
        "literals"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-002-radix-literal-accepted",
      "description": "Radix literals accept the reduced symbol alphabet used by the strict corpus",
      "input": {
        "source": "bits:radix = %+9&.!\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.bits",
              "datatype": "radix",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "radix",
        "literals"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-003-radix-leading-zero-payload-accepted",
      "description": "Radix payloads may use leading zeroes even though number literals do not",
      "input": {
        "source": "bits:radix[2] = %00100101\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.bits",
              "datatype": "radix[2]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "radix",
        "literals"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-004-radix-base-bracket-whitespace-accepted",
      "description": "Radix base brackets allow surrounding whitespace while keeping the integer contiguous",
      "input": {
        "source": "bits:radix[ 10 ] = %19\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.bits",
              "datatype": "radix[10]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "strict",
        "radix",
        "literals",
        "datatype"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-005-radix-generic-base-syntax-rejects",
      "description": "Radix datatype bases reject generic syntax and require bracket metadata",
      "input": {
        "source": "bits:radix<10> = %19\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR"
          }
        ],
        "warnings": []
      },
      "tags": [
        "strict",
        "radix",
        "rejection",
        "datatype"
      ],
      "spec_refs": [
        "specs/04-official/v1/value-types-v1.md"
      ]
    },
    {
      "id": "core-numenc-006a-radix-empty-base-brackets-reject",
      "description": "Radix datatype bases reject empty bracket forms",
      "input": {
        "source": "empty:radix[] = %1\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR"
          }
        ],
        "warnings": []
