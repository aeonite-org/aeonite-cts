    {
      "id": "core-numenc-007-base64-forms-accepted",
      "description": "Representative base64 literal spellings remain accepted in strict typed bindings",
      "input": {
        "source": "payload:base64 = $abc-_+/==\nblue:base64 = $FF_FF_FF_\na1:base64 = $F__F\na2:base64 = $_FF\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.payload",
              "datatype": "base64",
              "kind": "binding"
            },
            {
              "path": "$.blue",
              "datatype": "base64",
              "kind": "binding"
            },
            {
              "path": "$.a1",
              "datatype": "base64",
              "kind": "binding"
            },
            {
              "path": "$.a2",
              "datatype": "base64",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
