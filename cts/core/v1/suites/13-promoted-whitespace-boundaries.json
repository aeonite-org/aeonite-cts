{
  "meta": {
    "suite_id": "promoted-whitespace-boundaries",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/structure-syntax-v1.md",
      "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md",
      "specs/04-official/v1/appendices/appendix-error-model.md"
    ]
  },
  "id": "promoted-whitespace-boundaries",
  "title": "Promoted Whitespace Boundary Rules",
  "tests": [
    {
      "id": "core-whitespace-001-structural-datatype-and-container-newlines-pass",
      "description": "Newlines between structural tokens are accepted in datatype and container boundaries",
      "input": {
        "source": "a\n:\nlist\n<\n  n\n>\n=\n[\n  2\n  3\n]\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": "list<n>",
              "kind": "binding"
            },
            {
              "path": "$.a[0]",
              "datatype": null,
              "kind": "binding"
            },
            {
              "path": "$.a[1]",
              "datatype": null,
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "whitespace",
        "strict",
        "datatypes",
        "containers"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md#6-newline-rules",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md"
      ]
    },
    {
      "id": "core-whitespace-002-attribute-and-node-head-newlines-pass",
      "description": "Newlines between attribute, type, and node-head structural tokens remain valid",
      "input": {
        "source": "value\n@{\n  meta\n  :\n  n\n  =\n  1\n}\n:\nnode\n=\n<tag\n@{\n  role = \"demo\"\n}\n>\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.value",
              "datatype": "node",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "whitespace",
        "strict",
        "attributes",
        "nodes"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md#3-attributes",
        "specs/04-official/v1/structure-syntax-v1.md#54-node-children",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md"
      ]
    },
    {
      "id": "core-whitespace-003-separator-literal-token-split-reject",
      "description": "A newline that splits a separator literal token is rejected",
      "input": {
        "source": "a =\n^\n0.0\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "phaseLabel": "Parsing"
          }
        ],
        "warnings": []
      },
      "tags": [
        "whitespace",
        "strict",
        "separator",
        "reject"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md#62-newline-forbidden-in-compact-tokens",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md"
      ]
    },
    {
      "id": "core-whitespace-004-separator-spec-boundary-newlines-pass",
      "description": "Newlines around separator spec bracket boundaries are accepted when the separator character remains contiguous",
      "input": {
        "source": "size:sep\n[\nx\n]\n= ^300x250\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.size",
              "datatype": "sep[x]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "whitespace",
        "strict",
        "separator"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md#4-separator-specs",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md"
      ]
    },
    {
      "id": "core-whitespace-005-separator-space-before-comment-pass",
      "description": "A space before a trailing line comment ends a separator literal payload cleanly outside quoted segments",
      "input": {
        "source": "g:sep[|] = ^aaa // d\n",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.g",
              "datatype": "sep[|]",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "whitespace",
        "strict",
        "separator",
        "comments"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    },
    {
      "id": "core-whitespace-006-separator-raw-space-reject",
      "description": "An unquoted interior space ends a separator payload and leaves trailing raw text as a syntax error",
      "input": {
        "source": "g:sep[|] = ^aaa bbb\n",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR"
          }
        ],
        "warnings": []
      },
      "tags": [
        "whitespace",
        "strict",
        "separator",
        "reject"
      ],
      "spec_refs": [
        "specs/04-official/v1/structure-syntax-v1.md",
        "specs/04-official/v1/appendices/appendix-whitespace-boundaries.md",
        "specs/04-official/v1/appendices/appendix-error-model.md"
      ]
    }
  ]
}
