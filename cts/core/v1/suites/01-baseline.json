{
  "meta": {
    "suite_id": "baseline",
    "lane": "core",
    "sut_protocol": "cts.protocol.v1",
    "spec_refs": [
      "specs/04-official/v1/AEON-spec-v1.md"
    ]
  },
  "id": "baseline",
  "title": "Core Baseline Parse and Addressing",
  "tests": [
    {
      "id": "core-baseline-001",
      "description": "Simple strict parse succeeds with normalized binding projection",
      "input": {
        "source": "a:number = 1",
        "mode": "strict"
      },
      "expected": {
        "ok": true,
        "errors": [],
        "warnings": [],
        "result": {
          "parse_ok": true,
          "bindings": [
            {
              "path": "$.a",
              "datatype": "number",
              "kind": "binding"
            }
          ]
        }
      },
      "tags": [
        "baseline",
        "parse-pass"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#6-type-system",
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "core-baseline-002",
      "description": "Invalid syntax fails with deterministic parse diagnostic shape",
      "input": {
        "source": "a = {",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "baseline",
        "parse-fail"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#11-processing-phases"
      ]
    },
    {
      "id": "core-baseline-003-strict-reserved-only-custom-datatype-reject",
      "description": "Strict mode rejects custom datatype by default (reserved_only)",
      "input": {
        "source": "aeon:mode = \"strict\"\ncolor:stroke = #ff00ff",
        "mode": "strict"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "CUSTOM_DATATYPE_NOT_ALLOWED",
            "path": "$.color",
            "phase": null
          }
        ],
        "warnings": [],
        "result": {
          "parse_ok": false
        }
      },
      "tags": [
        "baseline",
        "datatype-policy",
        "strict"
      ],
      "spec_refs": [
        "specs/04-official/v1/AEON-spec-v1.md#6-strict-vs-transport",
        "specs/04-official/v1/AEON-v1-compliance.md#7-strict-mode-requirements"
      ]
    },
