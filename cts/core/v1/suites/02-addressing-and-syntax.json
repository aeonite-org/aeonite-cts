          "parse_ok": false
        }
      },
      "tags": ["typed-values", "nodes", "reject"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md", "specs/04-official/v1/appendices/appendix-node-model.md"]
    },
    {
      "id": "core-addr-020-anonymous-typed-object-entry-reject",
      "description": "Anonymous typed values are invalid inside objects because objects require keyed bindings",
      "input": {
