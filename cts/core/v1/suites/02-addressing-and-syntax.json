    },
    {
      "id": "core-addr-022-list-binding-head-bracket-entry-reject",
      "description": "A typed list binding cannot omit the equals sign and place keyed-looking content directly after the datatype",
      "input": {
        "source": "a:list[ n = 3 ]",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
