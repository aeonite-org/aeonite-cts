          "parse_ok": false
        }
      },
      "tags": ["typed-values", "reject"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-addr-018-anonymous-typed-list-nesting-reject",
      "description": "Anonymous typed values annotate only immediate values and cannot wrap another anonymous typed value",
      "input": {
        "source": "a:list = [:n = :n = 3]",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
          }
        ],
        "warnings": [],
