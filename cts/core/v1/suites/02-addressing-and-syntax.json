    },
    {
      "id": "core-addr-023-list-binding-head-empty-type-reject",
      "description": "A typed list binding cannot omit the equals sign and use an empty anonymous type annotation in brackets",
      "input": {
        "source": "a:list[ : = 3 ]",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
        "errors": [
          {
            "code": "SYNTAX_ERROR",
            "path": "$",
            "phase": null
