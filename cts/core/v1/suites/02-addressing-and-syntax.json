      "tags": ["typed-values", "reject"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-addr-017-anonymous-typed-binding-value-reject",
      "description": "Anonymous typed values cannot appear directly where a binding value is expected",
      "input": {
        "source": "a:n = :n = 3",
