      "tags": ["typed-values", "lists", "reject"],
      "spec_refs": ["specs/04-official/v1/structure-syntax-v1.md"]
    },
    {
      "id": "core-addr-024-list-binding-head-missing-element-reject",
      "description": "A typed list binding cannot omit the equals sign and place an equals token directly inside brackets",
      "input": {
        "source": "a:list[ = 3 ]",
        "mode": "transport"
      },
      "expected": {
        "ok": false,
